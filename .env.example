# ─── Application ─────────────────────────────────────────────────────────────
APP_NAME=Patabrava
APP_TAGLINE=Captação de imóveis · Lisboa & Cascais
APP_ENV=development          # development | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
LOG_FILE=logs/patabrava.log

# Signature appended to outreach messages drafted in the dashboard.
# Per-tenant — leave blank for a neutral closing.
CONTACT_SIGNATURE=Equipa Patabrava · AMI 23783

# ─── Database ─────────────────────────────────────────────────────────────────
# Phase 1: SQLite (local)
DATABASE_URL=sqlite:///data/patabrava.db

# Phase 2: PostgreSQL (uncomment + set when migrating)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/patabrava

# ─── Proxy Configuration ──────────────────────────────────────────────────────
USE_PROXIES=false
# Comma-separated list of proxies — format: http://user:pass@host:port
PROXY_LIST=

# ─── Scraping ─────────────────────────────────────────────────────────────────
SCRAPE_DELAY_MIN=2.0         # minimum seconds between requests
SCRAPE_DELAY_MAX=6.0         # maximum seconds between requests
MAX_RETRIES=3
REQUEST_TIMEOUT=30
HEADLESS_BROWSER=true        # set false for visual debugging of Playwright

# ─── Target Zones (comma-separated) ──────────────────────────────────────────
# Patabrava — máxima cobertura para captação de FSBO (proprietários directos).
# Inclui Lisboa município + 22 freguesias (sweep paralelo para passar o cap de
# 1000 do município) + Linha de Cascais + Margem Sul + Setúbal centro.
# Ver scrapers/imovirtual.py:99 para slugs válidos. Remove zonas se quiseres
# correr mais rápido — cada zona adiciona ~3-7min de scrape.
TARGET_ZONES=Lisboa,Lisboa-Alvalade,Lisboa-Areeiro,Lisboa-Arroios,Lisboa-Avenidas-Novas,Lisboa-Beato,Lisboa-Belem,Lisboa-Benfica,Lisboa-Campo-de-Ourique,Lisboa-Campolide,Lisboa-Carnide,Lisboa-Estrela,Lisboa-Lumiar,Lisboa-Marvila,Lisboa-Misericordia,Lisboa-Olivais,Lisboa-Parque-das-Nacoes,Lisboa-Penha-de-Franca,Lisboa-Santa-Clara,Lisboa-Santa-Maria-Maior,Lisboa-Santo-Antonio,Lisboa-Sao-Domingos-de-Benfica,Lisboa-Sao-Vicente,Cascais,Sintra,Oeiras,Amadora,Loures,Odivelas,Mafra,Almada,Seixal,Sesimbra,Barreiro,Montijo,Setubal

# ─── Scheduler ────────────────────────────────────────────────────────────────
SCHEDULE_TIME=08:00          # daily run time (HH:MM local)
SCHEDULE_ENABLED=true

# ─── Scoring ──────────────────────────────────────────────────────────────────
HOT_SCORE_THRESHOLD=60
WARM_SCORE_THRESHOLD=40

# ─── Notifications — Email (optional) ────────────────────────────────────────
ALERT_EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# ─── Notifications — Telegram (optional) ─────────────────────────────────────
ALERT_TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Nurture sequences (optional overrides) ──────────────────────────────────
# Day-offsets after last touch when a reminder is created for each stage.
# Defaults: novo=1,3 · contactado=3,7,14 · negociacao=2,5,10
# Templates default to short PT-language hints — uncomment to override.
# NURTURE_NOVO_DAYS=1,3
# NURTURE_CONTACTADO_DAYS=3,7,14
# NURTURE_NEGOCIACAO_DAYS=2,5,10
# NURTURE_NOVO_TEMPLATE=📞 Lembrete · primeira chamada hoje
# NURTURE_CONTACTADO_TEMPLATE=💬 Follow-up sugerido (WhatsApp ou email)
# NURTURE_NEGOCIACAO_TEMPLATE=✉ Reforçar proposta ou marcar visita
