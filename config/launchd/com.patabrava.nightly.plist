<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.patabrava.nightly</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-c</string>
    <string>cd /Users/highlevel/ScrapperPatabrava &amp;&amp; STAMP=$(date +%Y%m%d_%H%M%S) &amp;&amp; LOG=logs/run_${STAMP}.log &amp;&amp; /Library/Frameworks/Python.framework/Versions/3.14/bin/python3 main.py run > $LOG 2>&amp;1 &amp; SP=$! ; ./scripts/auto_after_run.sh $SP &gt; /dev/null 2&gt;&amp;1 &amp;</string>
  </array>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key><integer>3</integer>
    <key>Minute</key><integer>0</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>/Users/highlevel/ScrapperPatabrava/logs/launchd_out.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/highlevel/ScrapperPatabrava/logs/launchd_err.log</string>

  <key>RunAtLoad</key>
  <false/>
</dict>
</plist>
